# ============================================================
# Lumos Server 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# ---- 应用基础 ----
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- 数据库 ----
# SQLite (开发环境默认)
DATABASE_URL=sqlite+aiosqlite:///./lumos.db
# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/lumos

# ---- AI 模型配置 ----
# 支持 OpenAI 兼容接口 (DeepSeek / Claude / 通义千问)
LLM_API_KEY=sk-your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat

# 嵌入模型 (用于 RAG 向量检索)
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_BASE_URL=https://api.deepseek.com/v1
EMBEDDING_MODEL_NAME=text-embedding-v3

# ---- 安全 ----
# API 密钥 (可选, 留空则不启用鉴权)
API_SECRET_KEY=

# ---- 日志 ----
LOG_LEVEL=DEBUG
