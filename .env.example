# ========================================
# Lawbor 环境变量配置模板
# ========================================
# 复制此文件为 .env.local 并填入实际值
# cp .env.example .env.local

# DeepSeek API (用于 AI 对话和合同审查)
# 获取地址: https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=your-deepseek-api-key-here
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com

# DIFY API (用于其他 AI 功能)
# 获取地址: https://dify.ai/
VITE_DIFY_API_KEY=your-dify-api-key-here

# Supabase 配置 (用于用户认证和数据持久化)
# 获取地址: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# 企查查 API (用于企业风险查询)
# 获取地址: https://agent.qcc.com/
QCC_API_KEY=your-qcc-api-key-here

# 腾讯云语音合成 (用于模拟面试 TTS)
# 获取地址: https://console.cloud.tencent.com/cam/capi
TENCENT_SECRET_ID=your-secret-id-here
TENCENT_SECRET_KEY=your-secret-key-here

# 应用 URL (本地开发)
APP_URL=http://localhost:3000

# ========================================
# 注意事项:
# ========================================
# 1. VITE_ 前缀的变量会暴露给前端代码
# 2. 不要提交包含真实密钥的文件到 Git
# 3. .env.local 文件会被 Git 自动忽略
# 4. Supabase URL 和 Key 可以在项目设置 > API 中找到
# 5. QCC_API_KEY 仅在服务端使用，不会暴露给前端